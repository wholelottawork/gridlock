# ── Inference ────────────────────────────────────────────────────────────────
# Groq (recommended for testing — fast and free):
VLLM_ENDPOINT=https://api.groq.com/openai
VLLM_API_KEY=gsk_your_groq_key_here
# Self-hosted vLLM (production):
# VLLM_ENDPOINT=http://localhost:8000
# VLLM_API_KEY=

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Solana ───────────────────────────────────────────────────────────────────
# Helius: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Alchemy: https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com
ROUTER_KEYPAIR_PATH=~/.config/solana/id.json

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: supabase.com → project → Settings → API
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-service-role-key

# ── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys clients must send as Bearer tokens.
# Leave empty to disable auth (dev mode).
API_KEYS=sk-grid-changeme1,sk-grid-changeme2

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Misc ─────────────────────────────────────────────────────────────────────
WATCHER_SAMPLE_RATE=0.05
