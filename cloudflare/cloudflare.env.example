# Cloudflare Tunnel for gridlock-backend
#
# Prerequisites:
#   - Added to Cloudflare (nameservers pointed to Cloudflare)
#   - cloudflared installed and logged in: cloudflared tunnel login
#
# Usage:
#   cp cloudflare/cloudflare.env.example cloudflare/cloudflare.env
#   bash cloudflare/setup-tunnel.sh
#   bash cloudflare/up.sh

GRIDLOCK_TUNNEL_HOSTNAME=api.domain.com
GRIDLOCK_TUNNEL_NAME=gridlock-api
GRIDLOCK_BACKEND_PORT=8081
