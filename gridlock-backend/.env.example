# ── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated bootstrap keys (optional; also accepts DB keys when Supabase is configured)
API_KEYS=
# Dev only: trust X-Gridlock-Wallet on /v1/keys without signature
GRIDLOCK_INSECURE_KEY_MANAGEMENT=false
# HMAC secret for 24h console session tokens (defaults to SUPABASE_KEY in dev)
# GRIDLOCK_WALLET_SESSION_SECRET=
# Off-chain $LOCK credits (set false to disable balance checks)
GRIDLOCK_BILLING_ENABLED=true
# Credits for new wallets on first API use
GRIDLOCK_STARTING_CREDIT_LOCK=10
# Dev: enable POST /v1/billing/topup in console
GRIDLOCK_BILLING_DEV_TOPUP=true
# Explorer cluster for invoice tx links (devnet | mainnet-beta)
SOLANA_CLUSTER=devnet
GRIDLOCK_INVOICE_CRON=true
GRIDLOCK_MIN_DEPOSIT_LOCK=1
# Passive staking (Phase C)
GRIDLOCK_STAKING_ENABLED=true
GRIDLOCK_MIN_STAKE_LOCK=1
# Unstake cooldown seconds (604800 = 7 days; use 60 for dev)
# GRIDLOCK_STAKE_COOLDOWN_SEC=604800
# Enable after FeeCollector redeploy with claim_unstake instruction
# GRIDLOCK_STAKING_CLAIM_ENABLED=true
# Optional: protect POST /v1/billing/invoices/close-all for external cron
# GRIDLOCK_INVOICE_CRON_SECRET=

# ── Misc ─────────────────────────────────────────────────────────────────────
WATCHER_SAMPLE_RATE=0.05
NEXT_PUBLIC_API_URL=http://localhost:8080
