{
  "name": "gridlock-worker",
  "version": "0.1.0",
  "description": "Gridlock GPU Worker Desktop Client",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "bundle-python": "node scripts/bundle-python.cjs",
    "prepackage": "node scripts/bundle-python.cjs",
    "package": "npm run build && electron-builder",
    "preview": "electron-vite preview"
  },
  "build": {
    "appId": "network.gridlock.worker",
    "productName": "Gridlock Worker",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "artifactName": "Gridlock-Worker-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "Gridlock-Worker-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "Gridlock-Worker-${version}.${ext}"
    },
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": ["**/*", "!**/__pycache__/**", "!**/.venv/**"]
      },
      {
        "from": "python-runtime",
        "to": "python-runtime",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "out/**/*"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "framer-motion": "^11.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
